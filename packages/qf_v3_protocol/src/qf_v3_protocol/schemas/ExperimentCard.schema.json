{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantfactory.local/qf-v3-protocol/0.1/ExperimentCard.schema.json",
  "title": "ExperimentCard",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "schema_name", "schema_version", "experiment_card"],
  "properties": {
    "protocol_version": { "const": "qf-v3-protocol-0.1" },
    "schema_name": { "const": "ExperimentCard" },
    "schema_version": { "const": "0.1.2" },
    "experiment_card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "experiment_id",
        "lab_id",
        "research_question",
        "hypothesis",
        "benchmark_pack_ids",
        "method_ids",
        "evaluation_plan",
        "expected_artifact_types"
      ],
      "properties": {
        "experiment_id": { "type": "string", "minLength": 1 },
        "lab_id": { "type": "string", "minLength": 1 },
        "research_question": { "type": "string", "minLength": 1 },
        "hypothesis": { "type": "string", "minLength": 1 },
        "benchmark_pack_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "method_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "evaluation_plan": { "type": "string", "minLength": 1 },
        "expected_artifact_types": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      }
    }
  }
}
