{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantfactory.local/qf-v3-protocol/0.1/SourceRef.schema.json",
  "title": "SourceRef",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version", "schema_name", "schema_version", "source_ref"],
  "properties": {
    "protocol_version": { "const": "qf-v3-protocol-0.1" },
    "schema_name": { "const": "SourceRef" },
    "schema_version": { "const": "0.1.2" },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_type",
        "source_version_hash",
        "segment_refs",
        "metadata_safety"
      ],
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "source_type": { "type": "string", "minLength": 1 },
        "source_version_hash": { "type": "string", "minLength": 1 },
        "segment_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["segment_id", "span_type", "start", "end", "quote_hash"],
            "properties": {
              "segment_id": { "type": "string", "minLength": 1 },
              "span_type": { "type": "string", "minLength": 1 },
              "start": { "type": "integer", "minimum": 0 },
              "end": { "type": "integer", "minimum": 0 },
              "quote_hash": { "type": "string", "minLength": 1 }
            }
          }
        },
        "metadata_safety": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "raw_source_material_included",
            "private_or_provider_payload_included",
            "synthetic_or_placeholder_only"
          ],
          "properties": {
            "raw_source_material_included": { "type": "boolean" },
            "private_or_provider_payload_included": { "type": "boolean" },
            "synthetic_or_placeholder_only": { "type": "boolean" }
          }
        }
      }
    }
  }
}
